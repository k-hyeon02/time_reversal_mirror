{
  "experiment": {
    "name": "stage1_single_speaker",
    "output_dir": "outputs/stage1_single_speaker_nompe"
  },
  "dataset": {
    "librispeech_root": null,
    "ms_snsd_root": null,
    "train_samples": 256,
    "val_samples": 64,
    "batch_size": 4,
    "num_workers": 0,
    "seed": 1337,
    "profile": "stage1",
    "rotate_arrays": true
  },
  "simulation": {
    "sample_rate": 16000,
    "segment_seconds": 1.0,
    "max_speakers": 1,
    "snr_db": [
      -5.0,
      5.0
    ],
    "utterance_sir_db": [
      -5.0,
      15.0
    ],
    "noise_sir_db": [
      0.5,
      15.0
    ],
    "rt60_s": [
      0.2,
      1.3
    ],
    "room_size_min_m": [
      3.0,
      3.0,
      2.5
    ],
    "room_size_max_m": [
      10.0,
      8.0,
      6.0
    ],
    "source_distance_m": [
      0.5,
      10.0
    ],
    "azimuth_deg": [
      0.0,
      360.0
    ],
    "elevation_deg": [
      30.0,
      150.0
    ],
    "min_speaker_gap_deg": 10.0,
    "min_wall_distance_m": 0.1,
    "min_noise_distance_m": 2.5,
    "rir_diffuse_attenuation_db": 12.0,
    "rir_end_attenuation_db": 40.0,
    "vad_frame_ms": 20,
    "vad_aggressiveness": 3
  },
  "feature": {
    "sample_rate": 16000,
    "speed_of_sound": 343.0,
    "n_fft": 256,
    "hop_length": 64,
    "win_length": 256,
    "freq_min_hz": 300.0,
    "freq_max_hz": 3500.0,
    "num_frequency_bands": 8,
    "num_azimuth_bins": 36,
    "num_elevation_bins": 7,
    "azimuth_range_deg": [
      0.0,
      360.0
    ],
    "elevation_range_deg": [
      30.0,
      150.0
    ],
    "apply_time_reverse": true,
    "apply_phat": true,
    "log_compression": true,
    "normalize_per_sample": true,
    "eps": 1e-08
  },
  "label": {
    "sigma_azimuth_deg": 10.0,
    "sigma_elevation_deg": 12.0
  },
  "model": {
    "architecture": "trm_multiband_unet",
    "in_channels": 8,
    "base_channels": 32,
    "num_blocks": 2,
    "dropout": 0.1,
    "geometry_hidden_dim": 64,
    "context_dim": 128,
    "attention_heads": 4,
    "use_geometry_conditioning": true
  },
  "optim": {
    "epochs": 12,
    "lr": 0.0003,
    "weight_decay": 0.0001,
    "grad_clip_norm": 5.0,
    "amp": false
  },
  "evaluation": {
    "top_k": 1,
    "decision_threshold": 0.2,
    "nms_kernel_size": 3
  }
}